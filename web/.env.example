# LearnX web environment template
# Copy to web/.env.local for local development, or configure the same keys in Vercel.

NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SUPABASE_URL=
# Supabase renamed anon keys to publishable keys. Either variable name works in LearnX.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
