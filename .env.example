# LearnX environment template
# Copy to .env.local for local development and fill values.
# Do not commit real secrets.

# Runtime mode: dev | prod
LEARNX_ENV=dev

# Required in prod mode for CORS allow-list
LEARNX_FRONTEND_URL=http://localhost:3000

# Database Configuration
# LOCAL: Use H2 in-memory (for development without PostgreSQL)
# LEARNX_DB_URL=jdbc:h2:mem:learnx;MODE=PostgreSQL;DB_CLOSE_DELAY=-1;DATABASE_TO_LOWER=TRUE
# LEARNX_DB_USERNAME=sa
# LEARNX_DB_PASSWORD=

# LOCAL: Use local PostgreSQL docker container
LEARNX_DB_URL=jdbc:postgresql://localhost:5432/learnx
LEARNX_DB_USERNAME=postgres
LEARNX_DB_PASSWORD=postgres

# PRODUCTION: Use Supabase PostgreSQL
# LEARNX_DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# LEARNX_DB_USERNAME=postgres
# LEARNX_DB_PASSWORD=<your-supabase-password>

# Database Behavior
LEARNX_JPA_DDL_AUTO=update
LEARNX_JPA_SHOW_SQL=false
LEARNX_JPA_FORMAT_SQL=false

# JWT / Authentication
# LOCAL DEV: Use simple secret key (min 32 chars for HS256)
LEARNX_JWT_SECRET=your-local-dev-secret-key-that-is-at-least-32-characters-long

# PRODUCTION: Use Supabase auth endpoints
# LEARNX_JWT_ISSUER_URI=https://YOUR_PROJECT_REF.supabase.co/auth/v1
# LEARNX_JWT_JWK_SET_URI=https://YOUR_PROJECT_REF.supabase.co/auth/v1/jwks

# Frontend/CORS Configuration
LEARNX_FRONTEND_URL=http://localhost:3000
LEARNX_ALLOWED_ORIGINS=http://localhost:3000

# Tutor safety and debug controls
LEARNX_DEBUG_PROMPTS=false
LEARNX_MAX_QUESTION_LENGTH=2000

# AI/search providers (optional)
LEARNX_GEMINI_API_KEY=
LEARNX_GEMINI_MODEL=gemini-2.5-flash
LEARNX_BRAVE_API_KEY=
LEARNX_TAVILY_API_KEY=
LEARNX_YOUTUBE_API_KEY=
LEARNX_PEXELS_API_KEY=

# Optional aliases for Google-key powered providers
LEARNX_GOOGLE_API_KEY=
LEARNX_GOOGLE_API_KEY_2=
LEARNX_GOOGLE_API_KEY_3=

# Runtime tuning
LEARNX_REQUEST_TIMEOUT_SECONDS=20
LEARNX_SEARCH_MAX_RESULTS=5

# Frontend public runtime
# Copy these into web/.env.local for local development, or set them in Vercel for the web app.
# NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
