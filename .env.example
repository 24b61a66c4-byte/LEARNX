# LearnX API Keys Template - Copy to .env.local and fill values
# NEVER commit .env.local to git!

# Gemini: https://aistudio.google.com/app/apikey
LEARNX_GEMINI_API_KEY=your_gemini_api_key_here

# Tavily: https://app.tavily.com/home/api-keys
LEARNX_TAVILY_API_KEY=your_tavily_api_key_here

# Optional overrides
LEARNX_GEMINI_MODEL=gemini-2.5-flash
LEARNX_REQUEST_TIMEOUT_SECONDS=20
LEARNX_SEARCH_MAX_RESULTS=5

# Usage:
# Windows: for /f "tokens=1,2 delims==" %i in (.env.local) do set %i=%j
# Or use VSCode env vars / dotenv plugin
# Vercel: Project Settings > Environment Variables
