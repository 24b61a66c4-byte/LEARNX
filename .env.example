# LearnX environment template
# Copy to .env.local for local development and fill values.
# Do not commit real secrets.

# Runtime mode: dev | prod
LEARNX_ENV=dev

# Required in prod mode for CORS allow-list
LEARNX_FRONTEND_URL=http://localhost:3000

# Database (local Docker defaults; override for Supabase/Postgres hosts)
LEARNX_DB_URL=jdbc:postgresql://localhost:5432/learnx
LEARNX_DB_USERNAME=postgres
LEARNX_DB_PASSWORD=postgres
LEARNX_JPA_DDL_AUTO=update
LEARNX_JPA_SHOW_SQL=false
LEARNX_JPA_FORMAT_SQL=false

# Tutor safety and debug controls
LEARNX_DEBUG_PROMPTS=false
LEARNX_MAX_QUESTION_LENGTH=2000

# AI/search providers (optional)
LEARNX_GEMINI_API_KEY=
LEARNX_GEMINI_MODEL=gemini-2.5-flash
LEARNX_BRAVE_API_KEY=
LEARNX_TAVILY_API_KEY=

# Runtime tuning
LEARNX_REQUEST_TIMEOUT_SECONDS=20
LEARNX_SEARCH_MAX_RESULTS=5
